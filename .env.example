# FinPay environment template
#
# PRODUCTION (AWS):
# - Store real values in AWS Secrets Manager.
# - Encrypt secrets with AWS KMS.
# - Map secrets into ECS task environment variables using the same names below.
#
# LOCAL:
# - You can leave DB_* unset to use local fallback in includes/db_connect.php:
#   host=localhost, port=3306, user=root, pass=empty, db=ledgercore_db

# App
APP_ENV=production
API_ALLOWED_ORIGIN=https://your-frontend-domain

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Database
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=ledgercore_db
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Optional compatibility names (legacy support)
# DB_USER=your-db-user
# DB_PASS=your-db-password

# BTC deposit address generation
BTC_NETWORK=testnet
BTC_XPUB=your-watch-only-xpub-or-vpub
BTC_REQUIRED_CONFIRMATIONS=2

# Optional BTC watcher tuning
# Leave BTC_INDEXER_BASE_URL empty to use defaults:
# - mainnet: https://blockstream.info/api
# - testnet3: https://blockstream.info/testnet/api
# Alternative testnet3 provider:
# - https://api.blockcypher.com/v1/btc/test3
BTC_INDEXER_BASE_URL=
BTC_WATCHER_MAX_BLOCKS_PER_RUN=20
BTC_WATCHER_HTTP_TIMEOUT_SECONDS=12
BTC_WATCHER_MAX_RUNTIME_SECONDS=90
BTC_WATCHER_MAX_BACKFILL_BLOCKS=2000
BTC_WATCHER_MAX_ADDRESSES_PER_RUN=500
